# Copy to .env (or .env.local) and fill in.
# .env is git-ignored. Never commit secrets.

# ───── Neon Postgres ─────
# Get this from https://console.neon.tech/ (project → Connection Details → "Pooled" or "Direct").
# Use the pooled URL for serverless usage. Must include ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/dbname?sslmode=require

# ───── Firebase Authentication — server-side (Admin SDK) ─────
# Get from Firebase console → Project settings → Service accounts → Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the value as a single line, with newlines escaped as \n.
FIREBASE_PRIVATE_KEY=

# ───── Firebase Authentication — client-side (Web SDK) ─────
# Get from Firebase console → Project settings → General → Your apps (Web).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ───── API.Bible ─────
# https://scripture.api.bible/  (request a free key).
APIBIBLE_KEY=
# Bible IDs (per-version). Set whichever ones your key has access to.
# If a value is empty, that version is hidden in the UI (specs.md §9.2).
APIBIBLE_ID_NBLA=
APIBIBLE_ID_NVI=
APIBIBLE_ID_RVR1960=

# ───── Session ─────
# A 32+ byte random string for signing the auth session cookie.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=
